{
  "name": "@personaxis/persona.md",
  "version": "0.12.0",
  "description": "The living, governed AI persona toolchain (personaxis.md spec v1.1.0). Run `personaxis` for an interactive REPL where your persona talks, evolves (clamped + audited), and remembers; plus create (Genesis), validate, lint, compile/decompile, state, drift, jacobian, proof, push/pull, skills, overseer, team, orchestrate, sigil, sync, serve, and migrate (up to 0.10-to-1.0). Three-artifact model: personaxis.md (10-layer spec), PERSONA.md (compiled), state.json (runtime).",
  "keywords": [
    "ai",
    "agents",
    "persona",
    "persona-spec",
    "agent-personhood",
    "spec",
    "cli"
  ],
  "homepage": "https://personaxis.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/personaxis/personaxis.git",
    "directory": "packages/cli"
  },
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./linter": "./dist/linter/index.js"
  },
  "bin": {
    "personaxis": "dist/index.js",
    "personaxis-scan": "dist/scan-bin.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "node ../../scripts/embed-assets.mjs && tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "lint": "node ../../scripts/embed-assets.mjs && tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@personaxis/core": "workspace:*",
    "@personaxis/protocol": "workspace:*",
    "@personaxis/sdk": "workspace:*",
    "@personaxis/spec": "workspace:*",
    "@personaxis/tui": "workspace:*",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "gray-matter": "^4.0.3",
    "inquirer": "^12.5.2",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.0",
    "fast-check": "^4.8.0",
    "typescript": "^5.8.3",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
